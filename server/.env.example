# Server port
PORT=3000

# SQLite database path (relative to server/)
DATABASE_URL=./data/pump-or-rug.db

# Bags.fm API key for token data (currently disabled — API lacks market data)
BAGS_API_KEY=your-bags-fm-api-key

# Birdeye API key for settlement price data (free tier: 1000 req/day)
BIRDEYE_API_KEY=your-birdeye-api-key

# Privy authentication (JWT verified via JWKS endpoint)
PRIVY_APP_ID=your-privy-app-id
